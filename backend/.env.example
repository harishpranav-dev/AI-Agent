# AutoAgent Studio — Backend Environment Variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Anthropic Claude API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Tavily Web Search API key — get from https://tavily.com
TAVILY_API_KEY=tvly-your-key-here

# MongoDB Atlas connection string — get from Atlas dashboard
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/autoagent

# Frontend URL for CORS — local dev value shown; change in production
CORS_ORIGIN=http://localhost:5173

# Server port — Railway overrides this automatically in production
PORT=8000